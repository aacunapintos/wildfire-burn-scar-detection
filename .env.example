# Copy to .env and fill in your credentials. Never commit .env to git.

# Copernicus Data Space Ecosystem (CDSE) — https://dataspace.copernicus.eu
CDSE_USER=your_email@example.com
CDSE_PASSWORD=your_password

# NASA FIRMS API key — https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_API_KEY=your_key_here

# Copernicus Climate Data Store (ERA5) — https://cds.climate.copernicus.eu
CDS_URL=https://cds.climate.copernicus.eu/api
CDS_KEY=your_uid:your_api_key
